{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2016" /* Compila a ES2016 */,
    "module": "commonjs" /* Usa CommonJS para Node */,
    "rootDir": "./src" /* Carpeta de código fuente */,
    "outDir": "./dist" /* Carpeta de salida compilada */,
    "strict": true /* Habilita todas las comprobaciones estrictas */,
    "esModuleInterop": true /* Permite importar CommonJS correctamente */,
    "forceConsistentCasingInFileNames": true /* Asegura consistencia de mayúsculas/minúsculas en imports */,
    "skipLibCheck": true /* Ignora chequeo de tipos en archivos de librería */
  },
  "include": ["src/**/*"] /* Incluye todos los archivos TS en src */,
  "exclude": ["node_modules", "dist"] /* Excluye node_modules y dist */
}
